# Copy to .env and run: createdb stellarmarket (if needed). Requires PostgreSQL running locally.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stellarmarket?schema=public"
JWT_SECRET="your-super-secret-jwt-key-change-this"
PORT=5000
FRONTEND_URL="http://localhost:3000"

# Optional: override default upload directory (default: backend/uploads)
UPLOAD_DIR="./uploads"
# Optional: avatar storage (default: UPLOAD_DIR/avatars). Set to a path for local storage.
AVATAR_UPLOAD_DIR="./uploads/avatars"
# Redis Configuration for caching
REDIS_URL="redis://localhost:6379"

# SMTP Configuration for email sending
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="StellarMarket <noreply@stellarmarket.com>"

# Stellar / Soroban configuration
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
STELLAR_RPC_URL="https://soroban-testnet.stellar.org"
STELLAR_HORIZON_URL="https://horizon-testnet.stellar.org"
ESCROW_CONTRACT_ID=""
DISPUTE_CONTRACT_ID=""
REPUTATION_CONTRACT_ID=""
NATIVE_TOKEN_ID=""
